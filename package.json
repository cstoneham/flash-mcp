{
  "name": "@definitive-fi/flash-mcp",
  "version": "0.1.1",
  "description": "MCP server for trading on the Definitive Flash API",
  "license": "MIT",
  "type": "module",
  "publishConfig": {
    "access": "public"
  },
  "bin": {
    "flash-mcp": "dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "node --import tsx src/index.ts",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "prepare": "tsc"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/DefinitiveCo/flash-mcp.git"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.18.0",
    "@solana/web3.js": "^1.95.0",
    "bs58": "^6.0.0",
    "tweetnacl": "^1.0.3",
    "viem": "^2.21.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/node": "^22",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  },
  "overrides": {
    "rpc-websockets": {
      "uuid": "^9.0.1"
    }
  },
  "engines": {
    "node": ">=20"
  }
}
